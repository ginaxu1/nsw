# Copy to ".env" (same folder) and adjust values.
#
# Notes:
# - Docker Compose auto-loads a ".env" file ONLY from the directory you run it in.
#   If you run from the repo root, prefer:
#     docker compose --env-file temporal/.env -f temporal/docker-compose.yml up -d
# - Do NOT commit real passwords/tokens.

# ------------------------------------------------------------------------------
# Image versions (pin these for repeatable environments)
# ------------------------------------------------------------------------------
POSTGRESQL_VERSION=16-alpine
TEMPORAL_VERSION=1.28.3
TEMPORAL_ADMINTOOLS_VERSION=1.28.3
TEMPORAL_UI_VERSION=2.48.0

# ------------------------------------------------------------------------------
# PostgreSQL (used by Temporal)
# ------------------------------------------------------------------------------
# Host-side bind + port publishing.
# For production on a single machine, consider restricting exposure:
#   TEMPORAL_DB_BIND_HOST=127.0.0.1
TEMPORAL_DB_BIND_HOST=0.0.0.0
TEMPORAL_DB_PORT=55435

# DB credentials
TEMPORAL_DB_USERNAME=temporal
TEMPORAL_DB_PASSWORD=temporal

# Optional DB names (also used by scripts/setup-postgres.sh)
TEMPORAL_DB_NAME=temporal
TEMPORAL_VISIBILITY_DB_NAME=temporal_visibility

# ------------------------------------------------------------------------------
# Temporal server
# ------------------------------------------------------------------------------
# Host-side bind + port publishing.
# For production, consider restricting exposure:
#   TEMPORAL_BIND_HOST=127.0.0.1
TEMPORAL_BIND_HOST=0.0.0.0
TEMPORAL_PORT=7233

# Dynamic config file name from temporal/dynamicconfig (mounted read-only).
# Examples: development-sql.yaml
TEMPORAL_DYNAMIC_CONFIG_FILE=development-sql.yaml

# ------------------------------------------------------------------------------
# Namespace bootstrap (temporal-create-namespace init container)
# ------------------------------------------------------------------------------
TEMPORAL_NAMESPACE=default
# Retention is specified in days.
TEMPORAL_NAMESPACE_RETENTION_DAYS=3

# ------------------------------------------------------------------------------
# Temporal UI
# ------------------------------------------------------------------------------
# Host-side bind + port publishing.
# For production, consider restricting exposure:
#   TEMPORAL_UI_BIND_HOST=127.0.0.1
TEMPORAL_UI_BIND_HOST=0.0.0.0
TEMPORAL_UI_PORT=8233

# Comma-separated list; UI uses this for CORS.
# If you run portals locally, keeping http://localhost:3000 is typical.
TEMPORAL_UI_CORS_ORIGINS=http://localhost:3000

